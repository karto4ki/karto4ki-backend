LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_MOCK=false 
APPLE_KEY_ID=XXXXXXXXXX
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_CLIENT_ID=com.karto4ki.web
APPLE_PRIVATE_KEY_PATH=/app/keys/apple/AuthKey_XXXXXXXXXX.p8
APPLE_REDIRECT_URI=https://karto4ki.com/auth/apple/callback
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://karto4ki.com/auth/google/callback
YANDEX_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YANDEX_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
YANDEX_REDIRECT_URI=https://karto4ki.com/auth/yandex/callback

SMTP_PORT=587
SMTP_USERNAME=noreply@karto4ki.com
SMTP_PASSWORD=your-smtp-password-here
SMTP_FROM=noreply@karto4ki.com
SMTP_HOST=smtp.example.com

USER_DB_HOST=user-db
USER_DB_PORT=5432
USER_DB_USER=user
USER_DB_PASSWORD=change-me-to-secure-password
USER_DB_NAME=userdb

CARD_DB_HOST=card-db
CARD_DB_PORT=5432
CARD_DB_USER=card
CARD_DB_PASSWORD=change-me-to-secure-password
CARD_DB_NAME=carddb

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-to-secure-password

JWT_PRIVATE_KEY_PATH=/app/keys/rsa.pem
JWT_PUBLIC_KEY_PATH=/app/keys/rsa.pub

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-to-secure-password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=karto4ki-files

KAFKA_BROKERS=kafka:29092
KAFKA_CONSUMER_GROUP=ai-workers
KAFKA_TOPIC_TASKS=ai.generation.tasks
KAFKA_TOPIC_EVENTS=ai.generation.events

WORKER_CONCURRENCY=3

APP_ENV=development

LOG_LEVEL=info
